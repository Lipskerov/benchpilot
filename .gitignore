# Secrets — never commit
.env
*.local
# The GitHub MCP token is read from the environment, not from a committed file.
# .bob/mcp.json is safe to commit because it only references ${GITHUB_PERSONAL_ACCESS_TOKEN}.

# Python
__pycache__/
*.pyc
.venv/
venv/

# Data / DB (rebuildable)
benchpilot.db
data/*.csv
data/chroma/

# TRACK data/snapshot/*.jsonl (committed for reproducibility)
!data/snapshot/*.jsonl

# Generated static build (rebuilt from web-build/build_static.py)
site/

# Demo media — too large / binary for the repo
demo/*.mp4
demo/*.m4a
demo/*.mov
demo/*.wav
demo/.rec/video/
demo/.rec/node_modules/
.DS_Store
**/.DS_Store
